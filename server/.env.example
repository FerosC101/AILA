# Port the backend listens on (frontend points VITE_AILA_API_BASE_URL here)
PORT=8787

# OPTIONAL — enables AI auto-classification (/classify) via Gemini.
# Get a free key at https://aistudio.google.com/apikey (it starts with "AIza").
# The key's Google Cloud project must have the Generative Language API enabled
# with free-tier quota, or /classify returns HTTP 429 (limit: 0).
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_MODEL=gemini-2.5-flash

# OPTIONAL — enables search-assisted dead-link recovery in the scanner.
# Without it, the resolver uses heuristics only (redirects + sitemap + origin).
# Get a key at https://tavily.com (free tier available).
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx
