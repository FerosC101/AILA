    "multer": "^2.2.0",
    "pdfjs-dist": "^4.10.38",
    "playwright": "^1.60.0",
    "tesseract.js": "^7.0.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "22.10.2",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
